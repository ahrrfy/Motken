# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/mutqin

# Session (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=CHANGE_ME_TO_RANDOM_64_BYTE_HEX

# Server
PORT=5001
NODE_ENV=development
HTTPS_ENABLED=false

# Admin seed (only for initial setup, remove after seeding)
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=CHANGE_ME
# SEED_SECRET=CHANGE_ME

# Optional: Sentry DSN for error tracking
# SENTRY_DSN=

# Optional: Redis URL (defaults to redis://localhost:6379)
# REDIS_URL=redis://localhost:6379

# Optional: MinIO config (defaults to localhost:9000)
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
